MONGO_URL=mongodb+srv://<your_db_username>:<your_db_password>@cluster0.mongodb.net/?appName=VideoConferencing

PORT=8000
NODE_ENV=development

# Frontend Origins (Comma separated for CORS)
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Redis Connection URL (Upstash or Render)
REDIS_URL=rediss://default:<your-password>@<your-upstash-url>.upstash.io:32450

# JWT Authentication Secret
TOKEN_KEY=<super_secret_random_generated_key_for_jwt>

# LiveKit Cloud Connection (From Server Settings -> Keys)
LIVEKIT_API_KEY=<your_livekit_api_key>
LIVEKIT_API_SECRET=<your_livekit_api_secret>
LIVEKIT_WS_URL=wss://<your-project>.livekit.cloud

# Email (Resend API)
RESEND_API_KEY=your_resend_api_key
APP_URL=http://localhost:5173

# Google OAuth Credentials (From GCP Console)
GOOGLE_CLIENT_ID=<your_google_oauth_client_id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your_google_oauth_client_secret>
CLIENT_URL=http://localhost:5173
